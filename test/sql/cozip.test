# name: test/sql/cozip.test
# description: smoke test for read_cozip
# group: [cozip]

require cozip

statement ok
SELECT * FROM read_cozip('test/data/flat_store_6files.cozip') LIMIT 1;

statement ok
SELECT "name", "offset", "size" FROM read_cozip(
    'test/data/flat_store_6files.cozip',
    gdal_vsi := false
);

# With gdal_vsi := true (default), the result must include the
# cozip:gdal_vsi column wrapped in double quotes due to the colon.
statement ok
SELECT "cozip:gdal_vsi" FROM read_cozip('test/data/flat_store_6files.cozip')
LIMIT 1;
